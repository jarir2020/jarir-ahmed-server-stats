{
    "name": "jarir-ahmed/server-stats",
    "description": "A simple server stats package: counters, gauges, timers and system metrics over MySQL or SQLite.",
    "license": "MIT",
    "keywords": ["metrics", "monitoring", "server-stats", "counter", "gauge", "timer"],
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "ext-pdo_sqlite": "*"
    },
    "suggest": {
        "ext-pdo_mysql": "For MySQL storage backend (otherwise falls back to SQLite)"
    },
    "autoload": {
        "psr-4": {
            "JarirAhmed\\ServerStats\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JarirAhmed\\ServerStats\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
